# ============================================================
# AI Knowledge Assistant - Environment Variables
# Copy this file to .env and fill in your actual keys
# ============================================================

# --- LLM Provider ---
# Set LLM_PROVIDER to "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI key — required for embeddings (always needed)
# Also used for LLM generation when LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic key — only needed when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Model Configuration ---
# OpenAI models:    gpt-4o-mini (cheap), gpt-4o (powerful)
# Anthropic models: claude-haiku-4-5-20251001 (cheap), claude-sonnet-4-6 (powerful)
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-ada-002

# --- Storage Paths ---
CHROMA_PERSIST_DIR=./data/chroma_db
SQLITE_DB_PATH=./data/metadata.db

# --- RAG Configuration ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=4

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=10   # max requests per window
RATE_LIMIT_WINDOW=60     # window in seconds
